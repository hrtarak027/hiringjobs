# Admin login (required)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_strong_password_here

# Session encryption (required - min 32 characters)
SESSION_SECRET=generate-a-long-random-string-at-least-32-chars

# GitHub persistence (required on Vercel - commits jobs on every change)
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPO=your-username/hiring-jobs
GITHUB_BRANCH=main
GITHUB_DATA_PATH=data/jobs.json
